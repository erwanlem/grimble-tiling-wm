#. Translators: This is the name of a tab in the prefs window
#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:6 src/ui/prefs.ui:211
msgid "General"
msgstr "Generale"

#. Translators: This is the header for a preference group in the 'General' tab
#: src/ui/prefs.ui:14
msgid "Appearance"
msgstr "Aspetto"

#. Translators: This is the name of setting to set tile padding in the 'General' tab
#: src/ui/prefs.ui:26
msgid "Tile padding"
msgstr "Spaziatura tra finestre"

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:39
msgid "Focus-driven cursor"
msgstr "Cursore segue il focus"

#. Translators: This setting is under the preference group 'Appearance' in the 'General' tab
#: src/ui/prefs.ui:40
msgid ""
"If enabled, the cursor automatically moves to the top-left corner of the "
"focused window when changing focus using shortcuts."
msgstr ""
"Se abilitato, il cursore si sposta automaticamente nell'angolo in alto a "
"sinistra della finestra attiva quando lo si cambia con le scorciatoie."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:46
msgid "Highlight focus"
msgstr "Evidenzia la finestra attiva"

#. Translators: This setting is under the preference group 'Appearance' in the 'General' tab
#: src/ui/prefs.ui:47
msgid "If enabled, the focused window is highlighted by a colored rectangle."
msgstr "Se abilitato, la finestra attiva viene evidenziata da un rettangolo colorato."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:53
msgid "Rectangle color"
msgstr "Colore del rettangolo"

#. Translators: This is the name of setting to set tile padding in the 'General' tab
#: src/ui/prefs.ui:60
msgid "Focus rectangle size"
msgstr "Dimensione del rettangolo"

#. Translators: This is the header for the insertion group in the 'General' tab
#: src/ui/prefs.ui:78
msgid "Search bar position"
msgstr "Posizione della barra di ricerca"

#. Translators: This setting is under the preference group 'Tile insertion' in the 'General' tab
#: src/ui/prefs.ui:82
msgid "Left"
msgstr "Sinistra"

#. Translators: This setting is under the preference group 'Tile insertion' in the 'General' tab
#: src/ui/prefs.ui:92
msgid "Center"
msgstr "Centro"

#. Translators: This setting is under the preference group 'Tile insertion' in the 'General' tab
#: src/ui/prefs.ui:104
msgid "Right"
msgstr "Destra"

#. Translators: This is the header for the insertion group in the 'General' tab
#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:120 src/ui/prefs.ui:380
msgid "Multiple monitors"
msgstr "Monitor multipli"

#. Translators: This is the explanation for the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:121
msgid "Defines tile insertion behavior while using multiple monitors."
msgstr "Definisce il comportamento di inserimento delle finestre quando sono presenti più monitor."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:124
msgid "Best fit"
msgstr "Adattamento ottimale"

#. Translators: This is an explanation for the 'Best fit' option for the 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:125
msgid "Selects the least filled monitor."
msgstr "Seleziona il monitor meno occupato."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:134
msgid "Focus"
msgstr "Focus"

#. Translators: This is an explanation for the 'Focus' option for the 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:135
msgid "Selects the focused monitor."
msgstr "Seleziona il monitor attivo."

#. Translators: This is the header for the fullscreen group in the 'General' tab
#: src/ui/prefs.ui:149
msgid "Fullscreen behavior"
msgstr "Comportamento a schermo intero"

#. Translators: This is the explanation for the preference group 'Fullscreen behavior' in the 'General' tab
#: src/ui/prefs.ui:150
msgid ""
"You can either stay in fullscreen when switching between two windows "
"(default) or quit the fullscreen mode."
msgstr ""
"È possibile rimanere a schermo intero quando si passa da una finestra "
"all'altra (predefinito) oppure uscire dalla modalità schermo intero."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:153
msgid "Keep fullscreen"
msgstr "Mantieni schermo intero"

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:162
msgid "Quit fullscreen"
msgstr "Esci dallo schermo intero"

#. Translators: This is the name of a tab in the prefs window
#: src/ui/prefs.ui:182
msgid "Keybindings"
msgstr "Scorciatoie da tastiera"

#: src/ui/prefs.ui:192
msgid "Configuration"
msgstr "Configurazione"

#: src/ui/prefs.ui:196
msgid "None"
msgstr "Nessuno"

#: src/ui/prefs.ui:197
msgid "i3"
msgstr "i3"

#: src/ui/prefs.ui:198
msgid "Grimble"
msgstr "Grimble"

#: src/ui/prefs.ui:199
msgid "Custom"
msgstr "Personalizzato"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to close tile
#: src/ui/prefs.ui:216
msgid "Close tile"
msgstr "Chiudi finestra"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to open search bar
#: src/ui/prefs.ui:222
msgid "Search bar"
msgstr "Barra di ricerca"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to open settings
#: src/ui/prefs.ui:228
msgid "Grimble settings"
msgstr "Impostazioni di Grimble"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to maximize
#: src/ui/prefs.ui:234
msgid "Maximize tile"
msgstr "Massimizza finestra"

#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:243
msgid "Tile Focus"
msgstr "Focus su finestra"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus
#: src/ui/prefs.ui:247
msgid "Change focus"
msgstr "Cambia focus"

#. Translators: This is the explanation for the keybinding 'Move tile' in the 'Tile movement' preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:248
msgid ""
"Press this shortcut, then use directional arrows to change the focus. Press "
"`Escape` to abort."
msgstr ""
"Premi questa scorciatoia, poi usa i tasti direzionali per cambiare il focus. "
"Premi 'Escape' per annullare."

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus left
#: src/ui/prefs.ui:254
msgid "Focus left"
msgstr "Focus a sinistra"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus right
#: src/ui/prefs.ui:260
msgid "Focus right"
msgstr "Focus a destra"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus top
#: src/ui/prefs.ui:266
msgid "Focus Up"
msgstr "Focus su"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus bottom
#: src/ui/prefs.ui:272
msgid "Focus Down"
msgstr "Focus giù"

#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:282
msgid "Tile movement"
msgstr "Spostamento finestra"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut move tile
#: src/ui/prefs.ui:286
msgid "Move tile"
msgstr "Sposta tessera"

#. Translators: This is the explanation for the keybinding 'Move tile' in the 'Tile movement' preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:287
msgid ""
"Press this shortcut, then use a directional arrow to move a tile. Press "
"`Escape` to abort."
msgstr ""
"Premi questa scorciatoia, poi usa un tasto direzionale per spostare una finestra. "
"Premi 'Escape' per annullare."

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move left
#: src/ui/prefs.ui:293
msgid "Move Left"
msgstr "Sposta a sinistra"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move right
#: src/ui/prefs.ui:299
msgid "Move Right"
msgstr "Sposta a destra"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move top
#: src/ui/prefs.ui:305
msgid "Move Up"
msgstr "Sposta su"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move bottom
#: src/ui/prefs.ui:311
msgid "Move Down"
msgstr "Sposta giù"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut tile rotation
#: src/ui/prefs.ui:317
msgid "Tile Rotation"
msgstr "Rotazione delle finestre"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut tile rotation
#: src/ui/prefs.ui:323
msgid "Switch to next workspace"
msgstr "Passa all'area di lavoro successiva"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut tile rotation
#: src/ui/prefs.ui:329
msgid "Switch to previous workspace"
msgstr "Passa all'area di lavoro precedente"

#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:339
msgid "Tile resizing"
msgstr "Ridimensionamento finestre"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut tile resizing
#: src/ui/prefs.ui:343
msgid "Resize tile"
msgstr "Ridimensiona finestra"

#. Translators: This is the explanation for the keybinding 'Move tile' in the 'Tile movement' preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:344
msgid ""
"Press this shortcut, then use directional arrows to resize a tile. Press "
"`Escape` to abort."
msgstr ""
"Premi questa scorciatoia, poi usa i tasti direzionali per ridimensionare una finestra. "
"Premi 'Escape' per annullare."

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move left
#: src/ui/prefs.ui:351
msgid "Resize Left"
msgstr "Ridimensiona a sinistra"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move right
#: src/ui/prefs.ui:357
msgid "Resize Right"
msgstr "Ridimensiona a destra"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move top
#: src/ui/prefs.ui:363
msgid "Resize Top"
msgstr "Ridimensiona verso l'alto"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move bottom
#: src/ui/prefs.ui:369
msgid "Resize Bottom"
msgstr "Ridimensiona verso il basso"

#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:382
msgid "Keybindings related to multiple monitors actions."
msgstr "Scorciatoie da tastiera per le azioni su più monitor."

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move bottom
#: src/ui/prefs.ui:386
msgid "Move tile to next monitor"
msgstr "Sposta la finestra al monitor successivo"

#: src/ui/shortcutListener.ui:11
msgid ""
"Replace the keyboard shortcuts. Press 'space' or 'return' when listening for "
"a shortcut to append a new one to the existing shortcuts instead."
msgstr ""
"Sostituisce le scorciatoie da tastiera. Premi 'Spazio' o 'Invio' durante durante l’assegnazione "
"di una scorciatoia per aggiungerne una nuova a quelle esistenti."

#: src/ui/shortcutListener.ui:14 dist/prefs/shortcutListener.js:102
msgid "Disabled"
msgstr "Disabilitato"

#: src/ui/shortcutListener.ui:23
msgid "Clear the keyboard shortcuts"
msgstr "Cancella le scorciatoie da tastiera"

