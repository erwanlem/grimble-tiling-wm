#. Translators: This is the name of a tab in the prefs window
#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:6 src/ui/prefs.ui:218
msgid "General"
msgstr "Général"

#. Translators: This is the header for a preference group in the 'General' tab
#: src/ui/prefs.ui:14
msgid "Appearance"
msgstr "Apparence"

#. Translators: This is the name of setting to set tile padding in the 'General' tab
#: src/ui/prefs.ui:26
msgid "Tile padding"
msgstr "Marge entre les fenêtres"

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:39
msgid "Focus-driven cursor"
msgstr "Curseur focus"

#. Translators: This setting is under the preference group 'Appearance' in the 'General' tab
#: src/ui/prefs.ui:40
msgid ""
"If enabled, the cursor automatically moves to the top-left corner of the "
"focused window when changing focus using shortcuts."
msgstr ""
"Si activé, le curseur se déplace automatiquement en haut à droite de la "
"fenêtre sélectionnée."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:46
msgid "Hide close button"
msgstr "Masquer le bouton quitter"

#. Translators: This setting is under the preference group 'Appearance' in the 'General' tab
#: src/ui/prefs.ui:47
msgid "If enabled, the close button is hidden."
msgstr "Si activé, le bouton Fermer est retiré."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:53
msgid "Highlight focus"
msgstr "Mise en avant du focus"

#. Translators: This setting is under the preference group 'Appearance' in the 'General' tab
#: src/ui/prefs.ui:54
msgid "If enabled, the focused window is highlighted by a colored rectangle."
msgstr ""
"Si activé, la fenêtre sélectionnée est mise en avant par une bordure colorée."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:60
msgid "Rectangle color"
msgstr "Couleur de la bordure"

#. Translators: This is the name of setting to set tile padding in the 'General' tab
#: src/ui/prefs.ui:67
msgid "Focus rectangle size"
msgstr "Taille de la bordure"

#. Translators: This is the header for the insertion group in the 'General' tab
#: src/ui/prefs.ui:85
msgid "Search bar position"
msgstr "Position de la barre de recherche"

#. Translators: This setting is under the preference group 'Tile insertion' in the 'General' tab
#: src/ui/prefs.ui:89
msgid "Left"
msgstr "Gauche"

#. Translators: This setting is under the preference group 'Tile insertion' in the 'General' tab
#: src/ui/prefs.ui:99
msgid "Center"
msgstr "Centre"

#. Translators: This setting is under the preference group 'Tile insertion' in the 'General' tab
#: src/ui/prefs.ui:111
msgid "Right"
msgstr "Droite"

#. Translators: This is the header for the insertion group in the 'General' tab
#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:127 src/ui/prefs.ui:394
msgid "Multiple monitors"
msgstr "Plusieurs écrans"

#. Translators: This is the explanation for the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:128
msgid "Defines tile insertion behavior while using multiple monitors."
msgstr "Définis le comportement d'insertion sur plusieurs écrans."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:131
msgid "Best fit"
msgstr "Meilleur ajustement"

#. Translators: This is an explanation for the 'Best fit' option for the 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:132
msgid "Selects the least filled monitor."
msgstr "Sélectionne l'écran le moins rempli."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:141
msgid "Focus"
msgstr ""

#. Translators: This is an explanation for the 'Focus' option for the 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:142
msgid "Selects the focused monitor."
msgstr "Sélectionne l'écran actuelle."

#. Translators: This is the header for the fullscreen group in the 'General' tab
#: src/ui/prefs.ui:156
msgid "Fullscreen behavior"
msgstr "Plein écran"

#. Translators: This is the explanation for the preference group 'Fullscreen behavior' in the 'General' tab
#: src/ui/prefs.ui:157
msgid ""
"You can either stay in fullscreen when switching between two windows "
"(default) or quit the fullscreen mode."
msgstr ""
"Vous pouvez rester en plein écran lors du changement de fenêtre (par défaut) "
"ou quitter le mode plein écran."

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:160
msgid "Keep fullscreen"
msgstr "Garder plein écran"

#. Translators: This setting is under the preference group 'Multiple monitors' in the 'General' tab
#: src/ui/prefs.ui:169
msgid "Quit fullscreen"
msgstr "Quitter plein écran"

#. Translators: This is the name of a tab in the prefs window
#: src/ui/prefs.ui:189
msgid "Keybindings"
msgstr "Raccourcis clavier"

#: src/ui/prefs.ui:199
msgid "Configuration"
msgstr ""

#: src/ui/prefs.ui:203
msgid "None"
msgstr ""

#: src/ui/prefs.ui:204
msgid "i3"
msgstr ""

#: src/ui/prefs.ui:205
msgid "Grimble"
msgstr ""

#: src/ui/prefs.ui:206
msgid "Custom"
msgstr ""

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to close tile
#: src/ui/prefs.ui:223
msgid "Close tile"
msgstr "Fermer la fenêtre"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to open search bar
#: src/ui/prefs.ui:229
msgid "Search bar"
msgstr "Barre de recherche"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to open settings
#: src/ui/prefs.ui:235
msgid "Grimble settings"
msgstr "Paramètres de Grimble"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to maximize
#: src/ui/prefs.ui:241
msgid "Maximize tile"
msgstr "Maximiser la fenêtre"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to toggle tile/window
#: src/ui/prefs.ui:248
msgid "Toggle tile/window mode"
msgstr "Basculer en mode tile/fenêtre flottante"

#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:257
msgid "Tile Focus"
msgstr "Fenêtre courante"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus
#: src/ui/prefs.ui:261
msgid "Change focus"
msgstr "Changer la fenêtre courante"

#. Translators: This is the explanation for the keybinding 'Move tile' in the 'Tile movement' preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:262
msgid ""
"Press this shortcut, then use directional arrows to change the focus. Press "
"`Escape` to abort."
msgstr ""
"Presser ce raccourcis clavier puis utiliser les touches directionnelles pour "
"changer le focus. Presser `Echap` pour annuler l'opération."

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus left
#: src/ui/prefs.ui:268
msgid "Focus left"
msgstr "Focus gauche"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus right
#: src/ui/prefs.ui:274
msgid "Focus right"
msgstr "Focus droite"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus top
#: src/ui/prefs.ui:280
msgid "Focus Up"
msgstr "Focus haut"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut change focus bottom
#: src/ui/prefs.ui:286
msgid "Focus Down"
msgstr "Focus bas"

#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:296
msgid "Tile movement"
msgstr "Déplacement"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut move tile
#: src/ui/prefs.ui:300
msgid "Move tile"
msgstr "Déplacer une fenêtre"

#. Translators: This is the explanation for the keybinding 'Move tile' in the 'Tile movement' preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:301
msgid ""
"Press this shortcut, then use a directional arrow to move a tile. Press "
"`Escape` to abort."
msgstr ""
"Presser ce raccourcis puis utiliser une touche directionnelle pour déplacer "
"la fenêtre. Presser `Echap` pour annuler."

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move left
#: src/ui/prefs.ui:307
msgid "Move Left"
msgstr "Déplacer à gauche"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move right
#: src/ui/prefs.ui:313
msgid "Move Right"
msgstr "Déplacer à droite"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move top
#: src/ui/prefs.ui:319
msgid "Move Up"
msgstr "Déplacer en haut"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move bottom
#: src/ui/prefs.ui:325
msgid "Move Down"
msgstr "Déplacer en bas"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut tile rotation
#: src/ui/prefs.ui:331
msgid "Tile Rotation"
msgstr "Rotation des fenêtres"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut tile rotation
#: src/ui/prefs.ui:337
msgid "Switch to next workspace"
msgstr "Déplacer vers l'espace de travail suivant"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut tile rotation
#: src/ui/prefs.ui:343
msgid "Switch to previous workspace"
msgstr "Déplacer vers l'espace de travail précédent"

#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:353
msgid "Tile resizing"
msgstr "Redimensionnement"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut tile resizing
#: src/ui/prefs.ui:357
msgid "Resize tile"
msgstr "Redimensionner la fenêtre"

#. Translators: This is the explanation for the keybinding 'Move tile' in the 'Tile movement' preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:358
msgid ""
"Press this shortcut, then use directional arrows to resize a tile. Press "
"`Escape` to abort."
msgstr ""
"Presser ce raccourcis puis utiliser les flèches directionnelles pour "
"redimensionner la fenêtre. Presser `Echap` pour annuler."

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move left
#: src/ui/prefs.ui:365
msgid "Resize Left"
msgstr "Redimensionner vers la gauche"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move right
#: src/ui/prefs.ui:371
msgid "Resize Right"
msgstr "Redimensionner vers la droite"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move top
#: src/ui/prefs.ui:377
msgid "Resize Top"
msgstr "Redimensionner vers le haut"

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move bottom
#: src/ui/prefs.ui:383
msgid "Resize Bottom"
msgstr "Redimensionner vers le bas"

#. Translators: This is a header for a preference group in the 'Keybindings' tab
#: src/ui/prefs.ui:396
msgid "Keybindings related to multiple monitors actions."
msgstr "Raccourcis liés à l'utilisation de plusieurs écrans."

#. Translators: This is a keybinding in the 'General' preference group in the 'Keybindings' tab that set shortcut to move bottom
#: src/ui/prefs.ui:400
msgid "Move tile to next monitor"
msgstr "Déplacer la fenêtre sur l'écran suivant"

#: src/ui/shortcutListener.ui:11
msgid ""
"Replace the keyboard shortcuts. Press 'space' or 'return' when listening for "
"a shortcut to append a new one to the existing shortcuts instead."
msgstr ""
"Remplace le raccourcis clavier. Presser `Espace` ou `Entrée` lors de l'ajout "
"d'un raccourcis pour ajouter un raccourcis en plus de celui déjà existant."

#: src/ui/shortcutListener.ui:14 dist/prefs/shortcutListener.js:98
msgid "Disabled"
msgstr "Désactivé"

#: src/ui/shortcutListener.ui:23
msgid "Clear the keyboard shortcuts"
msgstr "Supprime le raccourcis"

